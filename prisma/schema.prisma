generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Article {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  image     String?
  createdAt DateTime @default(now())
}

model Activity {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime
  image       String?
  createdAt   DateTime @default(now())
}

model Ppdb {
  id          Int      @id @default(autoincrement())
  nama        String
  email       String
  kontak      String
  asalSekolah String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}